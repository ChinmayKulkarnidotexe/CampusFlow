# ── Database ──────────────────────────────────────────
DATABASE_URL=postgres://campusflow:campusflow_pass@localhost:5432/campusflow_db

# ── JWT Secrets (CHANGE THESE IN PRODUCTION!) ────────
JWT_ACCESS_SECRET=your-super-secret-access-key-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# ── Gmail SMTP ───────────────────────────────────────
# Generate an App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=CampusFlow <your-gmail@gmail.com>

# ── OTP Settings ─────────────────────────────────────
OTP_EXPIRY=300
OTP_COOLDOWN=60
OTP_MAX_ATTEMPTS=5

# ── SMTP Rate Limiting ──────────────────────────────
SMTP_RATE_LIMIT=10

# ── Server ───────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# ── Logging ──────────────────────────────────────────
RUST_LOG=backend=debug,tower_http=debug
